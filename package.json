{
  "name": "auteura",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "clean": "rm -rf dist node_modules",
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "build": "npm run typecheck && vite build",
    "preview": "vite preview",
    "test": "npm run test:unit",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:critical": "playwright test e2e/critical-path.spec.ts --reporter=line",
    "test:e2e:ci": "playwright test --reporter=line",
    "test:ci": "npm run typecheck && npm run lint && npm run test:unit && npm run test:e2e:ci"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mediapipe/tasks-vision": "^0.10.22",
    "@mui/icons-material": "^5.16.14",
    "@mui/material": "^5.16.14",
    "@sentry/react": "^10.6.0",
    "idb": "^8.0.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@playwright/test": "^1.58.2",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.19.15",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.4.1",
    "eslint": "^9.22.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "fake-indexeddb": "^6.2.5",
    "globals": "^16.0.0",
    "jsdom": "^28.1.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.1",
    "vite": "^6.2.1",
    "vite-plugin-pwa": "^0.21.2",
    "vitest": "^3.0.9"
  }
}
